  "project": {
    "name": "fleet-operations",
    "kind": "web-app",
    "description": "Fleet operations — a multi-tenant SaaS web app for fleet managers to monitor vehicles, drivers, trips, and incidents through a customizable 8x8 tile dashboard and a research workspace of 11 analytical tools.",
    "users": "Fleet managers (daily situational awareness), operations directors (trends & KPIs), data analysts (ad-hoc queries, SQL, exports), HR/safety officers (driver scoring, incident review). In-app roles: Admin, Analyst, Manager, Viewer."
  },
  "layout": {
    "kind": "web-app",
    "modules": [
      {
        "name": "backend",
        "path": "src/backend",
        "kind": "server",
        "language": "typescript",
        "manifest": "src/backend/package.json",
        "tests": "src/backend/tests",
        "independent": true
      },
      {
        "name": "frontend",
        "path": "src/frontend",
        "kind": "client",
        "language": "typescript",
        "manifest": "src/frontend/package.json",
        "tests": "src/frontend/tests",
        "independent": true
      }
    ],
    "exceptions": []
  },
  "stack": {
