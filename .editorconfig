root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Markdown — preserve trailing two spaces (hard line breaks)
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML — 2 spaces, fold long values manually
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Shell scripts — 4 spaces matches typical conventions
[*.sh]
indent_size = 4

# Makefiles require tabs
[Makefile]
indent_style = tab
